POSTGRES_DB=aitradex
POSTGRES_USER=aitradex
POSTGRES_PASSWORD=aitradex
POSTGRES_PORT=5432
REDIS_PORT=6379

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql://aitradex:aitradex@postgres:5432/aitradex
JDBC_DATABASE_URL=jdbc:postgresql://postgres:5432/aitradex
REDIS_URL=redis://redis:6379/0

BROKER_MODE=paper
RISK_MAX_QTY=100000
RISK_MAX_NOTIONAL=2000000
RISK_ALLOW_SHORT=false

QUOTE_PROVIDER=auto
GTJA_QUOTE_BASE_URL=
GTJA_QUOTE_ENDPOINT=/quote
GTJA_QUOTE_TOKEN=
GTJA_QUOTE_TIMEOUT_SEC=5
CREDENTIALS_FERNET_KEY=

