POSTGRES_DB=aitradex
POSTGRES_USER=aitradex
POSTGRES_PASSWORD=aitradex
POSTGRES_PORT=5432
REDIS_PORT=6379

APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

DATABASE_URL=postgresql://aitradex:aitradex@postgres:5432/aitradex
JDBC_DATABASE_URL=jdbc:postgresql://postgres:5432/aitradex
REDIS_URL=redis://redis:6379/0
STREAM_ENABLED=false
STREAM_BOOTSTRAP_SERVERS=redpanda:9092
STREAM_INGEST_TOKEN=
STREAM_TOPIC_MARKET_TICK=aitradex.market.tick.norm
STREAM_TOPIC_ORDER_EVENT=aitradex.trade.order.event
STREAM_TOPIC_RISK_EVENT=aitradex.trade.risk.event
STREAM_TOPIC_WORKFLOW_EVENT=aitradex.workflow.run.event
STREAM_TOPIC_DECISION_SIGNAL=aitradex.trade.decision.signal
FLINK_DECISION_WINDOW_SEC=30
FLINK_DECISION_UP_BPS=18
FLINK_DECISION_DOWN_BPS=18
FLINK_DECISION_COOLDOWN_SEC=20
FLINK_DECISION_MAX_RISK_REJECT_RATE_5M=35

BROKER_MODE=paper
RISK_MAX_QTY=100000
RISK_MAX_NOTIONAL=2000000
RISK_ALLOW_SHORT=false

QUOTE_PROVIDER=auto
GTJA_QUOTE_BASE_URL=
GTJA_QUOTE_ENDPOINT=/quote
GTJA_QUOTE_TOKEN=
GTJA_QUOTE_TIMEOUT_SEC=5
CREDENTIALS_FERNET_KEY=

